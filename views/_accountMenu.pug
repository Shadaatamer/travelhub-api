mixin navItem(link, text, icon, active)
    li(class=`${active ? 'side-nav--active' : ''}`)
        a(href=`${link}`)
            svg
                use(xlink:href=`/img/icons.svg#icon-${icon}`)
            | #{text}

nav.user-view__menu
    ul.side-nav
        +navItem('/me', 'Settings', 'settings', activePage === 'settings')
        +navItem('/my-tours', 'My bookings', 'briefcase', activePage === 'bookings')
        +navItem('/my-reviews', 'My reviews', 'star', activePage === 'reviews')
        +navItem('/billing', 'Billing', 'credit-card', activePage === 'billing')

    - if (user.role === 'admin')
        .admin-nav
            h5.admin-nav__heading Admin
            ul.side-nav
                +navItem('#', 'Manage tours', 'map')
                +navItem('#', 'Manage users', 'users')
                +navItem('#', 'Manage reviews', 'star')
                +navItem('#', 'Manage bookings', 'briefcase')